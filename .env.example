# Copy to .env and fill in. Never commit .env.

# Required — generate with: openssl rand -hex 32
SECRET_KEY=

# Public URL of your deployment (used to build short links)
APP_BASE_URL=https://slinkr.link

# --- Passwordless login (email codes) ---
# Resend API key (https://resend.com). Leave empty for dev mode:
# codes are printed to the container logs instead of emailed.
RESEND_API_KEY=
# Sender address — the domain must be verified in your Resend account
EMAIL_FROM="Slinkr <login@slinkr.link>"
# Comma-separated email domains that are auto-verified on first login.
# Everyone else can log in but needs admin approval for shortening/checking.
AUTO_VERIFY_DOMAINS=curtin.edu.au

# Optional: pre-create the admin account (no password — admin logs in by
# email code like everyone else). If unset, the first user to log in
# becomes admin.
ADMIN_EMAIL=
ADMIN_USERNAME=

# 1 if behind nginx/caddy/traefik (recommended), 0 if directly exposed
TRUST_PROXY=1

# 1 once you serve over HTTPS
SESSION_COOKIE_SECURE=1
