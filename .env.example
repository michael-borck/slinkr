# Copy to .env and fill in. Never commit .env.

# Required — generate with: openssl rand -hex 32
SECRET_KEY=

# Public URL of your deployment (used to build short links)
APP_BASE_URL=https://app.slinkr.eduserver.au

# Optional: bootstrap the first admin account on first start.
# Remove these after the first run.
ADMIN_USERNAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# 1 if behind nginx/caddy/traefik (recommended), 0 if directly exposed
TRUST_PROXY=1

# 1 once you serve over HTTPS
SESSION_COOKIE_SECURE=0
